{
    "name": "realityloop/foundry",
    "description": "Composer project template for the Drupal Foundry install profile using a relocated document root ",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/foundry",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": {
        "drupal": {
            "type": "composer",
            "url": "https://packages.drupal.org/8",
            "exclude": [
                "drupal/druxt",
                "drupal/entity_display_mode"
            ]
        },
        "drupal/druxt": {
            "type": "git",
            "url": "https://git.drupalcode.org/issue/druxt-3429976.git"
        },
        "drupal/entity_display_mode": {
            "type": "git",
            "url": "https://git.drupalcode.org/issue/entity_display_mode-3430161.git"
        }
    },
    "require": {
        "php": ">=8.3",
        "composer/installers": "^2.3",
        "cweagans/composer-patches": "^1.7.3",
        "drupal-tome/tome_drush": "dev-master",
        "drupal/admin_toolbar": "^3.6",
        "drupal/advanced_text_formatter": "^3.0@RC",
        "drupal/allowed_formats": "^3.0.1",
        "drupal/anonymous_redirect": "^2.4",
        "drupal/coffee": "^2.0",
        "drupal/config_filter": "^2.7",
        "drupal/config_ignore": "^3.2",
        "drupal/config_pages": "2.x-dev@dev",
        "drupal/content_lock": "^3.0@alpha",
        "drupal/core-composer-scaffold": "^11",
        "drupal/core-project-message": "^11",
        "drupal/core-recommended": "^11",
        "drupal/diff": "^2.0@beta",
        "drupal/druxt": "dev-project-update-bot-only",
        "drupal/dynamic_entity_reference": "^4.0@alpha",
        "drupal/entity_browser": "^2.11",
        "drupal/entity_browser_enhanced": "^2.0",
        "drupal/entity_clone": "^2.1@beta",
        "drupal/entity_display_mode": "dev-project-update-bot-only",
        "drupal/entity_usage": "^2.0@beta",
        "drupal/environment_indicator": "^4.0",
        "drupal/exclude_node_title": "^2.0",
        "drupal/field_group": "^4.0",
        "drupal/field_tools": "^1.0@alpha",
        "drupal/focal_point": "^2.1",
        "drupal/gin": "^5.0",
        "drupal/gin_login": "^2.1",
        "drupal/gin_toolbar": "^3.0",
        "drupal/jsonapi_hypermedia": "^1.10",
        "drupal/jsonapi_node_preview": "^1.0.0-beta4@beta",
        "drupal/jsonapi_node_preview_tab": "^1.0",
        "drupal/layout_paragraphs": "^3.0@alpha",
        "drupal/length_indicator": "^1.4",
        "drupal/linky": "^2.0@beta",
        "drupal/linkychecker": "^2.0",
        "drupal/linkyreplacer": "^2.4",
        "drupal/m4032404": "^2.0",
        "drupal/masquerade": "^2.0",
        "drupal/maxlength": "^3.1",
        "drupal/media_file_delete": "^1.3",
        "drupal/memcache": "^2.6",
        "drupal/metatag": "^2.2",
        "drupal/node_edit_protection": "^1.2",
        "drupal/oembed_providers": "^2.2",
        "drupal/paragraphs_ee": "10.0.x-dev@dev",
        "drupal/pathauto": "^1.14",
        "drupal/prevent_homepage_deletion": "^3.0",
        "drupal/redirect": "^1.12",
        "drupal/revision_log_default": "^1.4",
        "drupal/role_delegation": "^1.3",
        "drupal/scheduled_transitions": "^2.5",
        "drupal/simple_oauth": "6.0.x-dev@dev",
        "drupal/simple_sitemap": "^4.2",
        "drupal/tome": "^1.13",
        "drupal/username_enumeration_prevention": "^1.4",
        "drupal/viewfield": "^3.0@beta"
    },
    "require-dev": {
        "drupal/core-dev": "^11",
        "drush/drush": "^13",
        "phpspec/prophecy-phpunit": "^2"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "php": "8.3",
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true
        }
    },
    "scripts": {
        "post-create-project-cmd": ""
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "file-mapping": {
                "[web-root]/robots.txt": false
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you've installed Foundry  </>",
                "<bg=blue;fg=white>  from the realityloop/foundry template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps for an install in web/sites/default</>:",
                "  * Install the site via web UI by selecting `Use existing configuration' at install profile step",
                "  * Install the site via drush using 'drush si --existing-config' ",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        },
        "enable-patching": true,
        "patches": {
            "drupal/druxt": {
                "#3315030 - Add a wildcard route translator": "https://git.drupalcode.org/project/druxt/-/merge_requests/11.diff",
                "#3315035 - Cannot load the 'view' entity with NULL ID": "https://git.drupalcode.org/project/druxt/-/merge_requests/10.diff"
            },
            "drupal/gin": {
                "https://www.drupal.org/project/gin/issues/3217391#comment-14212917": "https://git.drupalcode.org/project/gin/-/merge_requests/647.diff"
            },
            "drupal/gin_toolbar": {
                "https://www.drupal.org/project/gin_toolbar/issues/3217393": "https://git.drupalcode.org/project/gin_toolbar/-/merge_requests/64.diff"
            },
            "drupal/tome": {
                "#3527948 - UriNormalizer layouts incompatibility": "https://www.drupal.org/files/issues/2025-06-02/tome-uri-normalizer-layout-paragraphs-2025-06-02.patch"
            },
            "drupal/node_edit_protection": {
                "https://www.drupal.org/project/node_edit_protection/issues/3196605#comment-14363624": "https://www.drupal.org/files/issues/2021-04-12/node_edit_protection-3196605-5.patch",
                "https://www.drupal.org/project/node_edit_protection/issues/3193652#comment-13970107": "https://www.drupal.org/files/issues/2021-01-20/3193652-2.patch"
            }
        }
    }
}
