{
  "name": "stuar-tc",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "postinstall": "[ \"$NETLIFY\" = \"true\" ] || SKIP_STORYBOOK=1 nuxt prepare",
    "build": "SKIP_STORYBOOK=1 nuxt build",
    "dev": "nuxt dev",
    "generate": "SKIP_STORYBOOK=1 nuxt generate",
    "preview": "SKIP_STORYBOOK=1 nuxt preview",
    "typecheck": "SKIP_STORYBOOK=1 nuxt typecheck",
    "storybook": "STORYBOOK_STANDALONE=1 storybook dev -p 6006 --no-open",
    "storybook:build": "STORYBOOK_STANDALONE=1 SKIP_STORYBOOK=1 storybook build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.nuxt\" \"#.output\" \"#modules\"",
    "lint:style": "stylelint \"app/**/*.vue\"",
    "lint:knip": "knip",
    "lint:spell": "cspell --config ../.cspell.json \"app/**/*.vue\" \"app/**/*.ts\" \"tests/**/*.ts\" \"content/**/*.md\"",
    "lint:all": "pnpm lint && pnpm lint:md && pnpm lint:style && pnpm lint:knip && pnpm lint:spell",
    "test": "SKIP_STORYBOOK=1 vitest run",
    "test:watch": "SKIP_STORYBOOK=1 vitest",
    "test:coverage": "SKIP_STORYBOOK=1 vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:design": "node tests/visual/compare-design.mjs"
  },
  "dependencies": {
    "@nuxt/content": "^3.0.0",
    "@nuxt/ui": "^3.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.11.1",
    "nuxt": "^4.0.0",
    "nuxt-og-image": "^6.7.2",
    "resend": "^6.17.2",
    "satori": "^0.26.0",
    "uqr": "^0.1.3",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/eslint": "^1.0.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/test-utils": "^3.17.0",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@playwright/test": "^1.61.1",
    "@storybook-vue/nuxt": "9.0.1",
    "@storybook/vue3": "9.1.2",
    "@stuartclark/ui": "link:../../ui",
    "@vitest/coverage-istanbul": "^3.2.6",
    "@vue/test-utils": "^2.4.0",
    "axe-core": "^4.12.1",
    "cspell": "^10.0.1",
    "eslint": "^9.0.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "happy-dom": "^20.10.6",
    "knip": "^6.19.0",
    "markdownlint-cli2": "^0.17.0",
    "nuxt-cloudflared-tunnel": "^0.1.0",
    "nuxt-gtag": "^4.1.0",
    "serve": "^14.2.6",
    "storybook": "9.1.2",
    "stylelint": "^16.0.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^37.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "unlighthouse": "^0.17.10",
    "vite": "7.3.6",
    "vitest": "^3.0.0",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^3.3.5",
    "wait-on": "^9.0.10"
  }
}
