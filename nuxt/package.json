{
  "name": "stuar-tc",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "postinstall": "[ \"$NETLIFY\" = \"true\" ] || SKIP_STORYBOOK=1 nuxt prepare",
    "build": "SKIP_STORYBOOK=1 nuxt build",
    "dev": "nuxt dev",
    "generate": "SKIP_STORYBOOK=1 nuxt generate",
    "preview": "SKIP_STORYBOOK=1 nuxt preview",
    "typecheck": "SKIP_STORYBOOK=1 nuxt typecheck",
    "storybook": "STORYBOOK_STANDALONE=1 storybook dev -p 6006 --no-open",
    "storybook:build": "STORYBOOK_STANDALONE=1 SKIP_STORYBOOK=1 storybook build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.nuxt\" \"#.output\" \"#modules\"",
    "lint:style": "stylelint \"app/**/*.vue\"",
    "lint:knip": "knip",
    "lint:spell": "cspell --config ../.cspell.json \"app/**/*.vue\" \"app/**/*.ts\" \"tests/**/*.ts\" \"content/**/*.md\"",
    "lint:all": "pnpm lint && pnpm lint:md && pnpm lint:style && pnpm lint:knip && pnpm lint:spell",
    "test": "SKIP_STORYBOOK=1 vitest run",
    "test:watch": "SKIP_STORYBOOK=1 vitest",
    "test:coverage": "SKIP_STORYBOOK=1 vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:design": "node tests/visual/compare-design.mjs",
    "size": "size-limit"
  },
  "dependencies": {
    "@nuxt/content": "^3.15.2",
    "@nuxt/ui": "^3.3.7",
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.11.1",
    "feed": "^6.0.0",
    "nuxt": "^4.5.0",
    "nuxt-og-image": "^6.7.4",
    "resend": "^6.18.0",
    "satori": "^0.29.0",
    "uqr": "^0.1.3",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@iconify-json/lucide": "^1.2.119",
    "@iconify-json/simple-icons": "^1.2.91",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/robots": "^6.1.3",
    "@nuxtjs/sitemap": "^8.3.0",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@storybook-vue/nuxt": "9.0.1",
    "@storybook/vue3": "9.1.20",
    "@stuartclark/ui": "link:../../ui",
    "@tailwindcss/typography": "^0.5.20",
    "@vitest/coverage-istanbul": "^3.2.7",
    "@vue/test-utils": "^2.4.11",
    "axe-core": "^4.12.1",
    "cspell": "^10.0.1",
    "druxt": "github:druxt/druxt.js#feature/337-nuxt3&path:packages/druxt",
    "druxt-schema": "github:druxt/druxt.js#feature/337-nuxt3&path:packages/schema",
    "eslint": "^9.39.5",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "happy-dom": "^20.11.1",
    "knip": "^6.29.0",
    "markdownlint-cli2": "^0.23.1",
    "nuxt-cloudflared-tunnel": "^0.1.1",
    "nuxt-gtag": "^4.1.0",
    "serve": "^14.2.6",
    "size-limit": "^12.1.0",
    "storybook": "9.1.2",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^37.0.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "unlighthouse": "^0.18.0",
    "vite": "7.3.6",
    "vitest": "^3.2.7",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^3.3.8",
    "wait-on": "^9.1.0"
  }
}
